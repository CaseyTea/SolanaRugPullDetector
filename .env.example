# API key required for client authentication on /api/* endpoints.
# If unset, auth is disabled (useful for local development).
# Generate with: openssl rand -base64 32
RUGPULL_API_KEY=

# Helius RPC API key for live ML feature extraction.
# Sign up at https://helius.dev for a free tier.
# If unset, the ML model cannot run on live tokens and /api/analyze
# returns mlPrediction: null with an error reason.
HELIUS_API_KEY=

# Set to 1 when deployed behind a reverse proxy (Cloudflare Tunnel,
# nginx, Caddy) so rate limiting sees the real client IP from
# X-Forwarded-For. Leave unset on directly-exposed servers.
TRUST_FORWARDED_HEADERS=
